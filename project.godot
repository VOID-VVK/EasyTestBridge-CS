; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be edited via code.

[application]

config/name="EasyTestBridge"
config/features=PackedStringArray("4.6", "C#")
run/main_scene="res://demo/Scenes/DemoScene.tscn"

[autoload]

EasyTestBridge="*res://addons/EasyTestBridge/EasyTestBridge.cs"
DemoTestSuiteRegistrar="*res://demo/Scripts/Tests/DemoTestSuiteRegistrar.cs"

[dotnet]

project/assembly_name="EasyTestBridge"

[editor_plugins]

enabled=PackedStringArray("res://addons/EasyTestBridge/plugin.cfg")
